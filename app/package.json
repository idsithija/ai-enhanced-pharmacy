{
  "name": "pharmacy-management-system",
  "version": "1.0.0",
  "private": true,
  "description": "AI-Enhanced Pharmacy Management System - Monorepo",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "build": "npm run build --workspace=backend && npm run build --workspace=frontend",
    "build:frontend": "npm run build --workspace=frontend",
    "build:backend": "npm run build --workspace=backend",
    "start": "npm run start --workspace=backend",
    "start:frontend": "npm run preview --workspace=frontend",
    "lint": "npm run lint --workspace=backend && npm run lint --workspace=frontend",
    "lint:frontend": "npm run lint --workspace=frontend",
    "lint:backend": "npm run lint --workspace=backend",
    "test": "npm run test --workspace=backend",
    "clean": "rimraf node_modules frontend/node_modules backend/node_modules frontend/dist backend/dist",
    "db:setup": "npm run db:setup --workspace=backend",
    "db:migrate": "npm run migrate --workspace=backend",
    "db:seed": "npm run seed --workspace=backend",
    "db:demo": "npm run db:demo --workspace=backend",
    "db:reset": "npm run db:reset --workspace=backend"
  },
  "keywords": [
    "pharmacy",
    "management",
    "ai",
    "react",
    "nodejs",
    "typescript",
    "monorepo"
  ],
  "author": "@idsithija",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "rimraf": "^5.0.5"
  }
}
